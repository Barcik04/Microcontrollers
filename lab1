}



void zad7(void) {
    unsigned int snake;

    AD1PCFG = 0xFFFF;
    TRISA = 0x0000;
    LATA = 0x0000;

    while(1) {
        for(int i = 0; i <= 5; i++) {
            snake = 0x0007 << i;   
            LATA = snake;
            __delay32(1000000);
        }

        for(int i = 4; i >= 1; i--) {
            snake = 0x0007 << i;
            LATA = snake;
            __delay32(1000000);
        }
    }
}

void zad8(void) {
    unsigned int lfsr = 0x3F; 
    unsigned int newBit;

    AD1PCFG = 0xFFFF;
    TRISA = 0x0000;
    LATA = 0x0000;

    while(1) {
        newBit = ((lfsr >> 5) ^ (lfsr >> 4) ^ (lfsr >> 3) ^ (lfsr >> 0)) & 1;

        lfsr = ((lfsr << 1) | newBit) & 0x3F;

        LATA = lfsr;

        __delay32(1000000);
    }
}


int main(void) {
    zad7();
    return 0;
}
