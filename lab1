void zad5(void) {
    unsigned int bcd;

    AD1PCFG = 0xFFFF;
    TRISA = 0x0000;
    LATA = 0x0000;

    while(1) {
        for(int i = 0; i < 100; i++) {
            int ones = i % 10;
            int tens = i / 10;

            bcd = (tens << 4) | ones;
            LATA = bcd;

            __delay32(1000000);
        }
    }
}






void zad6(void) {
    unsigned int bcd;

    AD1PCFG = 0xFFFF;
    TRISA = 0x0000;
    LATA = 0x0000;

    while(1) {
        for(int i = 99; i >= 0; i--) {
            int ones = i % 10;
